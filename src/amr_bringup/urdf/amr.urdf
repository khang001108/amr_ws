<?xml version="1.0"?>
<!--
  amr.urdf  —  Robot description cho AMR 2 bánh vi sai
  Wheel radius : 43.5 mm
  Wheel base   : 200 mm
  Wheel width  : 30 mm (ước tính, chỉnh lại nếu khác)
-->
<robot name="amr">

  <!-- ═══════════════════════════════════════
       BASE LINK (trung tâm robot)
  ═══════════════════════════════════════ -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.30 0.25 0.10"/>
      </geometry>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.30 0.25 0.10"/>
      </geometry>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="3.0"/>
      <inertia ixx="0.02" ixy="0" ixz="0"
               iyy="0.02" iyz="0" izz="0.03"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════
       FOOTPRINT LINK (cho Nav2)
  ═══════════════════════════════════════ -->
  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0.0435" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════════
       BÁNH TRÁI
  ═══════════════════════════════════════ -->
  <link name="wheel_left_link">
    <visual>
      <geometry>
        <cylinder radius="0.0435" length="0.030"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.0435" length="0.030"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0003" ixy="0" ixz="0"
               iyy="0.0003" iyz="0" izz="0.0006"/>
    </inertial>
  </link>

  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="wheel_left_link"/>
    <origin xyz="0 0.10 0" rpy="0 0 0"/>
    <axis   xyz="0 1 0"/>
  </joint>

  <!-- ═══════════════════════════════════════
       BÁNH PHẢI
  ═══════════════════════════════════════ -->
  <link name="wheel_right_link">
    <visual>
      <geometry>
        <cylinder radius="0.0435" length="0.030"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.0435" length="0.030"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0003" ixy="0" ixz="0"
               iyy="0.0003" iyz="0" izz="0.0006"/>
    </inertial>
  </link>

  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="wheel_right_link"/>
    <origin xyz="0 -0.10 0" rpy="0 0 0"/>
    <axis   xyz="0 1 0"/>
  </joint>

  <!-- ═══════════════════════════════════════
       CASTER WHEEL (bánh đỡ phía sau, passive)
  ═══════════════════════════════════════ -->
  <link name="caster_link">
    <visual>
      <geometry>
        <sphere radius="0.020"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.020"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0" ixz="0"
               iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="caster_link"/>
    <origin xyz="-0.12 0 -0.0235" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════════
       IMU FRAME (BNO055)
  ═══════════════════════════════════════ -->
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
  </joint>

</robot>
