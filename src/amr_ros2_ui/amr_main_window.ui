<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>AMRMainWindow</class>
 <widget class="QMainWindow" name="AMRMainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1400</width>
    <height>900</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>AMR Control Panel - ROS2</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
QMainWindow {
    background-color: #0d1117;
    color: #e6edf3;
}
QWidget#centralwidget {
    background-color: #0d1117;
}
QGroupBox {
    background-color: #161b22;
    border: 1px solid #30363d;
    border-radius: 8px;
    color: #58a6ff;
    font-size: 12px;
    font-weight: bold;
    margin-top: 10px;
    padding-top: 8px;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 6px;
    color: #58a6ff;
}
QPushButton {
    background-color: #21262d;
    border: 1px solid #30363d;
    border-radius: 6px;
    color: #e6edf3;
    padding: 6px 14px;
    font-size: 11px;
}
QPushButton:hover {
    background-color: #30363d;
    border-color: #58a6ff;
}
QPushButton:pressed {
    background-color: #1f6feb;
}
QPushButton#btn_connect {
    background-color: #238636;
    border-color: #2ea043;
    color: white;
    font-weight: bold;
}
QPushButton#btn_connect:hover {
    background-color: #2ea043;
}
QPushButton#btn_disconnect {
    background-color: #b91c1c;
    border-color: #dc2626;
    color: white;
}
QPushButton#btn_emergency_stop {
    background-color: #dc2626;
    border: 2px solid #ef4444;
    border-radius: 8px;
    color: white;
    font-size: 14px;
    font-weight: bold;
    min-height: 50px;
}
QPushButton#btn_emergency_stop:hover {
    background-color: #ef4444;
}
QPushButton#btn_nav_start {
    background-color: #1d4ed8;
    border-color: #3b82f6;
    color: white;
}
QPushButton#btn_slam_start {
    background-color: #7c3aed;
    border-color: #8b5cf6;
    color: white;
}
QLabel {
    color: #e6edf3;
    font-size: 11px;
}
QLabel#lbl_title {
    color: #58a6ff;
    font-size: 18px;
    font-weight: bold;
}
QLabel#lbl_status_indicator {
    background-color: #238636;
    border-radius: 8px;
    min-width: 16px;
    min-height: 16px;
    max-width: 16px;
    max-height: 16px;
}
QLineEdit, QSpinBox, QDoubleSpinBox, QComboBox {
    background-color: #0d1117;
    border: 1px solid #30363d;
    border-radius: 4px;
    color: #e6edf3;
    padding: 4px 8px;
    font-size: 11px;
}
QLineEdit:focus, QSpinBox:focus, QDoubleSpinBox:focus, QComboBox:focus {
    border-color: #58a6ff;
}
QComboBox::drop-down {
    border: none;
}
QComboBox::down-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 6px solid #58a6ff;
    margin-right: 6px;
}
QComboBox QAbstractItemView {
    background-color: #161b22;
    border: 1px solid #30363d;
    color: #e6edf3;
    selection-background-color: #1f6feb;
}
QTextEdit {
    background-color: #0d1117;
    border: 1px solid #30363d;
    border-radius: 4px;
    color: #7ee787;
    font-family: 'Courier New', monospace;
    font-size: 10px;
    padding: 4px;
}
QSlider::groove:horizontal {
    height: 6px;
    background: #30363d;
    border-radius: 3px;
}
QSlider::handle:horizontal {
    background: #58a6ff;
    width: 16px;
    height: 16px;
    margin: -5px 0;
    border-radius: 8px;
}
QSlider::sub-page:horizontal {
    background: #1f6feb;
    border-radius: 3px;
}
QProgressBar {
    background-color: #0d1117;
    border: 1px solid #30363d;
    border-radius: 4px;
    color: #e6edf3;
    text-align: center;
    font-size: 10px;
}
QProgressBar::chunk {
    background-color: #1f6feb;
    border-radius: 3px;
}
QTabWidget::pane {
    background-color: #161b22;
    border: 1px solid #30363d;
    border-radius: 8px;
}
QTabBar::tab {
    background-color: #0d1117;
    border: 1px solid #30363d;
    border-bottom: none;
    border-radius: 4px 4px 0 0;
    color: #8b949e;
    padding: 6px 16px;
    margin-right: 2px;
}
QTabBar::tab:selected {
    background-color: #161b22;
    color: #58a6ff;
    border-color: #30363d;
}
QTabBar::tab:hover {
    color: #e6edf3;
}
QScrollBar:vertical {
    background: #0d1117;
    width: 8px;
    border-radius: 4px;
}
QScrollBar::handle:vertical {
    background: #30363d;
    border-radius: 4px;
    min-height: 20px;
}
QScrollBar::handle:vertical:hover {
    background: #58a6ff;
}
QFrame#map_frame {
    background-color: #0a0f16;
    border: 1px solid #30363d;
    border-radius: 8px;
}
QCheckBox {
    color: #e6edf3;
    font-size: 11px;
}
QCheckBox::indicator {
    width: 14px;
    height: 14px;
    border: 1px solid #30363d;
    border-radius: 3px;
    background-color: #0d1117;
}
QCheckBox::indicator:checked {
    background-color: #1f6feb;
    border-color: #58a6ff;
}
QStatusBar {
    background-color: #161b22;
    border-top: 1px solid #30363d;
    color: #8b949e;
    font-size: 10px;
}
   </string>
  </property>
  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout" name="main_vlayout">
    <property name="spacing">
     <number>8</number>
    </property>
    <property name="leftMargin"><number>10</number></property>
     <property name="topMargin"><number>10</number></property>
     <property name="rightMargin"><number>10</number></property>
     <property name="bottomMargin"><number>10</number></property>

    <!-- HEADER BAR -->
    <item>
     <widget class="QFrame" name="header_frame">
      <property name="frameShape">
       <enum>QFrame::StyledPanel</enum>
      </property>
      <property name="styleSheet">
       <string notr="true">QFrame { background-color: #161b22; border: 1px solid #30363d; border-radius: 8px; }</string>
      </property>
      <layout class="QHBoxLayout" name="header_layout">
       <property name="leftMargin"><number>12</number></property>
     <property name="topMargin"><number>8</number></property>
     <property name="rightMargin"><number>12</number></property>
     <property name="bottomMargin"><number>8</number></property>
       <item>
        <widget class="QLabel" name="lbl_title">
         <property name="text">
          <string>🤖  AMR Control Panel</string>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QLabel" name="lbl_subtitle">
         <property name="text">
          <string>ROS2 Humble | Nav2 | SLAM Toolbox</string>
         </property>
         <property name="styleSheet">
          <string notr="true">color: #8b949e; font-size: 11px;</string>
         </property>
        </widget>
       </item>
       <item>
        <spacer>
         <property name="orientation"><enum>Qt::Horizontal</enum></property>
        </spacer>
       </item>
       <!-- ROS Status -->
       <item>
        <widget class="QFrame" name="ros_status_frame">
         <property name="styleSheet">
          <string notr="true">QFrame { background-color: #0d1117; border: 1px solid #30363d; border-radius: 6px; padding: 2px 8px; }</string>
         </property>
         <layout class="QHBoxLayout">
          <property name="spacing"><number>6</number></property>
          <property name="leftMargin"><number>6</number></property>
     <property name="topMargin"><number>4</number></property>
     <property name="rightMargin"><number>6</number></property>
     <property name="bottomMargin"><number>4</number></property>
          <item>
           <widget class="QLabel" name="lbl_ros_dot">
            <property name="text"><string></string></property>
            <property name="styleSheet">
             <string notr="true">background-color: #238636; border-radius: 5px; min-width: 10px; max-width: 10px; min-height: 10px; max-height: 10px;</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QLabel" name="lbl_ros_status">
            <property name="text"><string>ROS2: Connected</string></property>
            <property name="styleSheet">
             <string notr="true">color: #7ee787; font-size: 10px; font-weight: bold;</string>
            </property>
           </widget>
          </item>
         </layout>
        </widget>
       </item>
       <!-- Battery -->
       <item>
        <widget class="QFrame" name="battery_frame">
         <property name="styleSheet">
          <string notr="true">QFrame { background-color: #0d1117; border: 1px solid #30363d; border-radius: 6px; }</string>
         </property>
         <layout class="QHBoxLayout">
          <property name="spacing"><number>4</number></property>
          <property name="leftMargin"><number>8</number></property>
     <property name="topMargin"><number>4</number></property>
     <property name="rightMargin"><number>8</number></property>
     <property name="bottomMargin"><number>4</number></property>
          <item>
           <widget class="QLabel" name="lbl_battery_icon">
            <property name="text"><string>🔋</string></property>
           </widget>
          </item>
          <item>
           <widget class="QProgressBar" name="progressbar_battery">
            <property name="value"><number>78</number></property>
            <property name="minimumWidth"><number>80</number></property>
            <property name="maximumWidth"><number>80</number></property>
            <property name="styleSheet">
             <string notr="true">QProgressBar { font-size: 9px; } QProgressBar::chunk { background-color: #238636; }</string>
            </property>
           </widget>
          </item>
         </layout>
        </widget>
       </item>
       <!-- Time -->
       <item>
        <widget class="QLabel" name="lbl_time">
         <property name="text"><string>00:00:00</string></property>
         <property name="styleSheet">
          <string notr="true">color: #8b949e; font-size: 11px; min-width: 70px;</string>
         </property>
        </widget>
       </item>
      </layout>
     </widget>
    </item>

    <!-- MAIN CONTENT -->
    <item>
     <layout class="QHBoxLayout" name="content_layout">
      <property name="spacing"><number>8</number></property>

      <!-- LEFT PANEL: Connection + Control -->
      <item>
       <widget class="QWidget" name="left_panel">
        <property name="maximumWidth"><number>280</number></property>
        <property name="minimumWidth"><number>260</number></property>
        <layout class="QVBoxLayout" name="left_vlayout">
         <property name="spacing"><number>8</number></property>
         <property name="leftMargin"><number>0</number></property>
     <property name="topMargin"><number>0</number></property>
     <property name="rightMargin"><number>0</number></property>
     <property name="bottomMargin"><number>0</number></property>

         <!-- CONNECTION GROUP -->
         <item>
          <widget class="QGroupBox" name="grp_connection">
           <property name="title"><string> Serial Connection</string></property>
           <layout class="QVBoxLayout" name="conn_vlayout">
            <property name="spacing"><number>6</number></property>
            <item>
             <layout class="QHBoxLayout">
              <item>
               <widget class="QLabel"><property name="text"><string>Port:</string></property></widget>
              </item>
              <item>
               <widget class="QComboBox" name="combo_serial_port">
                <item><property name="text"><string>/dev/ttyUSB0</string></property></item>
                <item><property name="text"><string>/dev/ttyUSB1</string></property></item>
                <item><property name="text"><string>/dev/ttyACM0</string></property></item>
               </widget>
              </item>
             </layout>
            </item>
            <item>
             <layout class="QHBoxLayout">
              <item>
               <widget class="QLabel"><property name="text"><string>Baud:</string></property></widget>
              </item>
              <item>
               <widget class="QComboBox" name="combo_baudrate">
                <item><property name="text"><string>115200</string></property></item>
                <item><property name="text"><string>57600</string></property></item>
                <item><property name="text"><string>38400</string></property></item>
                <item><property name="text"><string>9600</string></property></item>
               </widget>
              </item>
             </layout>
            </item>
            <item>
             <layout class="QHBoxLayout">
              <item>
               <widget class="QPushButton" name="btn_refresh_ports">
                <property name="text"><string>↻ Refresh</string></property>
               </widget>
              </item>
              <item>
               <widget class="QPushButton" name="btn_connect">
                <property name="text"><string>Connect</string></property>
               </widget>
              </item>
              <item>
               <widget class="QPushButton" name="btn_disconnect">
                <property name="text"><string>Disconnect</string></property>
               </widget>
              </item>
             </layout>
            </item>
            <item>
             <widget class="QFrame" name="conn_status_frame">
              <property name="styleSheet">
               <string notr="true">QFrame { background: #0d1117; border: 1px solid #30363d; border-radius: 4px; padding: 4px; }</string>
              </property>
              <layout class="QHBoxLayout">
               <property name="leftMargin"><number>8</number></property>
     <property name="topMargin"><number>4</number></property>
     <property name="rightMargin"><number>8</number></property>
     <property name="bottomMargin"><number>4</number></property>
               <item>
                <widget class="QLabel" name="lbl_conn_dot">
                 <property name="text"><string></string></property>
                 <property name="styleSheet">
                  <string notr="true">background-color: #b91c1c; border-radius: 5px; min-width: 10px; max-width: 10px; min-height: 10px; max-height: 10px;</string>
                 </property>
                </widget>
               </item>
               <item>
                <widget class="QLabel" name="lbl_conn_status">
                 <property name="text"><string>Disconnected</string></property>
                 <property name="styleSheet">
                  <string notr="true">color: #f87171; font-size: 10px;</string>
                 </property>
                </widget>
               </item>
              </layout>
             </widget>
            </item>
           </layout>
          </widget>
         </item>

         <!-- ROBOT STATE GROUP -->
         <item>
          <widget class="QGroupBox" name="grp_robot_state">
           <property name="title"><string> Robot State</string></property>
           <layout class="QGridLayout" name="state_grid">
            <property name="spacing"><number>6</number></property>

            <item row="0" column="0">
             <widget class="QLabel"><property name="text"><string>X Position:</string></property></widget>
            </item>
            <item row="0" column="1">
             <widget class="QLabel" name="lbl_pos_x">
              <property name="text"><string>0.000 m</string></property>
              <property name="styleSheet"><string notr="true">color: #58a6ff; font-weight: bold;</string></property>
             </widget>
            </item>

            <item row="1" column="0">
             <widget class="QLabel"><property name="text"><string>Y Position:</string></property></widget>
            </item>
            <item row="1" column="1">
             <widget class="QLabel" name="lbl_pos_y">
              <property name="text"><string>0.000 m</string></property>
              <property name="styleSheet"><string notr="true">color: #58a6ff; font-weight: bold;</string></property>
             </widget>
            </item>

            <item row="2" column="0">
             <widget class="QLabel"><property name="text"><string>Heading:</string></property></widget>
            </item>
            <item row="2" column="1">
             <widget class="QLabel" name="lbl_heading">
              <property name="text"><string>0.00°</string></property>
              <property name="styleSheet"><string notr="true">color: #58a6ff; font-weight: bold;</string></property>
             </widget>
            </item>

            <item row="3" column="0">
             <widget class="QLabel"><property name="text"><string>Lin. Vel:</string></property></widget>
            </item>
            <item row="3" column="1">
             <widget class="QLabel" name="lbl_linear_vel">
              <property name="text"><string>0.000 m/s</string></property>
              <property name="styleSheet"><string notr="true">color: #fbbf24; font-weight: bold;</string></property>
             </widget>
            </item>

            <item row="4" column="0">
             <widget class="QLabel"><property name="text"><string>Ang. Vel:</string></property></widget>
            </item>
            <item row="4" column="1">
             <widget class="QLabel" name="lbl_angular_vel">
              <property name="text"><string>0.000 rad/s</string></property>
              <property name="styleSheet"><string notr="true">color: #fbbf24; font-weight: bold;</string></property>
             </widget>
            </item>

            <item row="5" column="0">
             <widget class="QLabel"><property name="text"><string>Left Enc:</string></property></widget>
            </item>
            <item row="5" column="1">
             <widget class="QLabel" name="lbl_enc_left">
              <property name="text"><string>0</string></property>
              <property name="styleSheet"><string notr="true">color: #a78bfa;</string></property>
             </widget>
            </item>

            <item row="6" column="0">
             <widget class="QLabel"><property name="text"><string>Right Enc:</string></property></widget>
            </item>
            <item row="6" column="1">
             <widget class="QLabel" name="lbl_enc_right">
              <property name="text"><string>0</string></property>
              <property name="styleSheet"><string notr="true">color: #a78bfa;</string></property>
             </widget>
            </item>

           </layout>
          </widget>
         </item>

         <!-- MANUAL CONTROL GROUP -->
         <item>
          <widget class="QGroupBox" name="grp_manual_control">
           <property name="title"><string> Manual Control (Teleop)</string></property>
           <layout class="QVBoxLayout">
            <property name="spacing"><number>6</number></property>

            <!-- D-Pad -->
            <item>
             <layout class="QGridLayout" name="dpad_grid">
              <property name="spacing"><number>4</number></property>

              <item row="0" column="1">
               <widget class="QPushButton" name="btn_forward">
                <property name="text"><string>▲</string></property>
                <property name="minimumSize"><size><width>50</width><height>40</height></size></property>
                <property name="maximumSize"><size><width>50</width><height>40</height></size></property>
               </widget>
              </item>
              <item row="1" column="0">
               <widget class="QPushButton" name="btn_left">
                <property name="text"><string>◀</string></property>
                <property name="minimumSize"><size><width>50</width><height>40</height></size></property>
                <property name="maximumSize"><size><width>50</width><height>40</height></size></property>
               </widget>
              </item>
              <item row="1" column="1">
               <widget class="QPushButton" name="btn_stop">
                <property name="text"><string>■</string></property>
                <property name="minimumSize"><size><width>50</width><height>40</height></size></property>
                <property name="maximumSize"><size><width>50</width><height>40</height></size></property>
                <property name="styleSheet">
                 <string notr="true">QPushButton { background-color: #7c3aed; border-color: #8b5cf6; }</string>
                </property>
               </widget>
              </item>
              <item row="1" column="2">
               <widget class="QPushButton" name="btn_right">
                <property name="text"><string>▶</string></property>
                <property name="minimumSize"><size><width>50</width><height>40</height></size></property>
                <property name="maximumSize"><size><width>50</width><height>40</height></size></property>
               </widget>
              </item>
              <item row="2" column="1">
               <widget class="QPushButton" name="btn_backward">
                <property name="text"><string>▼</string></property>
                <property name="minimumSize"><size><width>50</width><height>40</height></size></property>
                <property name="maximumSize"><size><width>50</width><height>40</height></size></property>
               </widget>
              </item>
              <item row="0" column="3" rowspan="3">
               <layout class="QVBoxLayout">
                <property name="spacing"><number>2</number></property>
                <item>
                 <widget class="QLabel"><property name="text"><string>Vel</string></property></widget>
                </item>
                <item>
                 <widget class="QSlider" name="slider_max_vel">
                  <property name="orientation"><enum>Qt::Vertical</enum></property>
                  <property name="minimum"><number>0</number></property>
                  <property name="maximum"><number>100</number></property>
                  <property name="value"><number>50</number></property>
                  <property name="minimumHeight"><number>80</number></property>
                 </widget>
                </item>
                <item>
                 <widget class="QLabel" name="lbl_vel_pct">
                  <property name="text"><string>50%</string></property>
                  <property name="styleSheet"><string notr="true">color: #58a6ff; font-size: 9px;</string></property>
                 </widget>
                </item>
               </layout>
              </item>
             </layout>
            </item>

            <!-- Speed params -->
            <item>
             <layout class="QFormLayout">
              <item row="0" column="0">
               <widget class="QLabel"><property name="text"><string>Max Linear (m/s):</string></property></widget>
              </item>
              <item row="0" column="1">
               <widget class="QDoubleSpinBox" name="spin_max_linear">
                <property name="minimum"><double>0.05</double></property>
                <property name="maximum"><double>2.00</double></property>
                <property name="singleStep"><double>0.05</double></property>
                <property name="value"><double>0.50</double></property>
               </widget>
              </item>
              <item row="1" column="0">
               <widget class="QLabel"><property name="text"><string>Max Angular (rad/s):</string></property></widget>
              </item>
              <item row="1" column="1">
               <widget class="QDoubleSpinBox" name="spin_max_angular">
                <property name="minimum"><double>0.1</double></property>
                <property name="maximum"><double>3.14</double></property>
                <property name="singleStep"><double>0.1</double></property>
                <property name="value"><double>1.00</double></property>
               </widget>
              </item>
             </layout>
            </item>

           </layout>
          </widget>
         </item>

         <!-- EMERGENCY STOP -->
         <item>
          <widget class="QPushButton" name="btn_emergency_stop">
           <property name="text"><string>⚠  EMERGENCY STOP</string></property>
          </widget>
         </item>

         <item>
          <spacer>
           <property name="orientation"><enum>Qt::Vertical</enum></property>
          </spacer>
         </item>

        </layout>
       </widget>
      </item>

      <!-- CENTER PANEL: Map + Tabs -->
      <item>
       <layout class="QVBoxLayout" name="center_vlayout">
        <property name="spacing"><number>8</number></property>

        <!-- MAP VIEW -->
        <item stretch="1">
         <widget class="QGroupBox" name="grp_map">
          <property name="title"><string> Map Visualization</string></property>
          <layout class="QVBoxLayout">
           <property name="spacing"><number>4</number></property>
           <property name="leftMargin"><number>4</number></property>
     <property name="topMargin"><number>4</number></property>
     <property name="rightMargin"><number>4</number></property>
     <property name="bottomMargin"><number>4</number></property>

           <!-- Map toolbar -->
           <item>
            <layout class="QHBoxLayout">
             <property name="spacing"><number>4</number></property>
             <item>
              <widget class="QPushButton" name="btn_map_fit">
               <property name="text"><string>⊡ Fit View</string></property>
               <property name="maximumWidth"><number>80</number></property>
              </widget>
             </item>
             <item>
              <widget class="QPushButton" name="btn_map_zoom_in">
               <property name="text"><string>+</string></property>
               <property name="maximumWidth"><number>32</number></property>
              </widget>
             </item>
             <item>
              <widget class="QPushButton" name="btn_map_zoom_out">
               <property name="text"><string>−</string></property>
               <property name="maximumWidth"><number>32</number></property>
              </widget>
             </item>
             <item>
              <widget class="QCheckBox" name="chk_show_lidar">
               <property name="text"><string>LiDAR</string></property>
               <property name="checked"><bool>true</bool></property>
              </widget>
             </item>
             <item>
              <widget class="QCheckBox" name="chk_show_path">
               <property name="text"><string>Path</string></property>
               <property name="checked"><bool>true</bool></property>
              </widget>
             </item>
             <item>
              <widget class="QCheckBox" name="chk_show_costmap">
               <property name="text"><string>Costmap</string></property>
               <property name="checked"><bool>false</bool></property>
              </widget>
             </item>
             <item>
              <spacer><property name="orientation"><enum>Qt::Horizontal</enum></property></spacer>
             </item>
             <item>
              <widget class="QLabel" name="lbl_map_coords">
               <property name="text"><string>Map: 0.00, 0.00</string></property>
               <property name="styleSheet"><string notr="true">color: #8b949e; font-size: 10px;</string></property>
              </widget>
             </item>
            </layout>
           </item>

           <!-- Map canvas -->
           <item>
            <widget class="QFrame" name="map_frame">
             <property name="frameShape"><enum>QFrame::StyledPanel</enum></property>
             <property name="minimumHeight"><number>100</number></property>
             <property name="styleSheet">
              <string notr="true">
QFrame#map_frame {
    background-color: #050a0f;
    border: 1px solid #30363d;
    border-radius: 6px;
}
              </string>
             </property>
            </widget>
           </item>

          </layout>
         </widget>
        </item>

        <!-- BOTTOM TABS -->
        <item stretch="0">
         <widget class="QTabWidget" name="tab_bottom">
          <property name="minimumHeight"><number>150</number></property>
          <property name="maximumHeight"><number>170</number></property>

          <!-- Console Tab -->
          <widget class="QWidget" name="tab_console">
           <attribute name="title"><string>📟 Console Log</string></attribute>
           <layout class="QVBoxLayout">
            <property name="leftMargin"><number>4</number></property>
     <property name="topMargin"><number>4</number></property>
     <property name="rightMargin"><number>4</number></property>
     <property name="bottomMargin"><number>4</number></property>
            <item>
             <layout class="QHBoxLayout">
              <item>
               <widget class="QLineEdit" name="edit_cmd_input">
                <property name="placeholderText"><string>Enter ROS2 command...</string></property>
               </widget>
              </item>
              <item>
               <widget class="QPushButton" name="btn_cmd_send">
                <property name="text"><string>Send</string></property>
                <property name="maximumWidth"><number>60</number></property>
               </widget>
              </item>
              <item>
               <widget class="QPushButton" name="btn_console_clear">
                <property name="text"><string>Clear</string></property>
                <property name="maximumWidth"><number>60</number></property>
               </widget>
              </item>
             </layout>
            </item>
            <item>
             <widget class="QTextEdit" name="text_console">
              <property name="readOnly"><bool>true</bool></property>
              <property name="html">
               <string>&lt;span style='color:#58a6ff'&gt;[AMR Control Panel] Initialized&lt;/span&gt;&lt;br&gt;
&lt;span style='color:#7ee787'&gt;[INFO] Waiting for ROS2 connection...&lt;/span&gt;&lt;br&gt;
&lt;span style='color:#7ee787'&gt;[INFO] Serial bridge node ready&lt;/span&gt;</string>
              </property>
             </widget>
            </item>
           </layout>
          </widget>

          <!-- Topics Tab -->
          <widget class="QWidget" name="tab_topics">
           <attribute name="title"><string>📡 ROS2 Topics</string></attribute>
           <layout class="QVBoxLayout">
            <property name="leftMargin"><number>4</number></property>
     <property name="topMargin"><number>4</number></property>
     <property name="rightMargin"><number>4</number></property>
     <property name="bottomMargin"><number>4</number></property>
            <item>
             <layout class="QHBoxLayout">
              <item>
               <widget class="QLabel"><property name="text"><string>Topic:</string></property></widget>
              </item>
              <item>
               <widget class="QLineEdit" name="edit_topic_filter">
                <property name="placeholderText"><string>Filter topics...</string></property>
               </widget>
              </item>
              <item>
               <widget class="QPushButton" name="btn_refresh_topics">
                <property name="text"><string>↻ Refresh</string></property>
                <property name="maximumWidth"><number>80</number></property>
               </widget>
              </item>
             </layout>
            </item>
            <item>
             <widget class="QTextEdit" name="text_topics">
              <property name="readOnly"><bool>true</bool></property>
              <property name="html">
               <string>&lt;span style='color:#58a6ff'&gt;/cmd_vel&lt;/span&gt; &lt;span style='color:#8b949e'&gt;[geometry_msgs/Twist]&lt;/span&gt;&lt;br&gt;
&lt;span style='color:#58a6ff'&gt;/odom&lt;/span&gt; &lt;span style='color:#8b949e'&gt;[nav_msgs/Odometry]&lt;/span&gt;&lt;br&gt;
&lt;span style='color:#58a6ff'&gt;/scan&lt;/span&gt; &lt;span style='color:#8b949e'&gt;[sensor_msgs/LaserScan]&lt;/span&gt;&lt;br&gt;
&lt;span style='color:#58a6ff'&gt;/map&lt;/span&gt; &lt;span style='color:#8b949e'&gt;[nav_msgs/OccupancyGrid]&lt;/span&gt;&lt;br&gt;
&lt;span style='color:#58a6ff'&gt;/amcl_pose&lt;/span&gt; &lt;span style='color:#8b949e'&gt;[geometry_msgs/PoseWithCovarianceStamped]&lt;/span&gt;&lt;br&gt;
&lt;span style='color:#58a6ff'&gt;/goal_pose&lt;/span&gt; &lt;span style='color:#8b949e'&gt;[geometry_msgs/PoseStamped]&lt;/span&gt;</string>
              </property>
             </widget>
            </item>
           </layout>
          </widget>

         </widget>
        </item>

       </layout>
      </item>

      <!-- RIGHT PANEL: Navigation + SLAM + Sensors -->
      <item>
       <widget class="QWidget" name="right_panel">
        <property name="maximumWidth"><number>280</number></property>
        <property name="minimumWidth"><number>260</number></property>
        <layout class="QVBoxLayout" name="right_vlayout">
         <property name="spacing"><number>8</number></property>
         <property name="leftMargin"><number>0</number></property>
     <property name="topMargin"><number>0</number></property>
     <property name="rightMargin"><number>0</number></property>
     <property name="bottomMargin"><number>0</number></property>

         <!-- NAVIGATION GROUP -->
         <item>
          <widget class="QGroupBox" name="grp_navigation">
           <property name="title"><string> Navigation (Nav2)</string></property>
           <layout class="QVBoxLayout">
            <property name="spacing"><number>6</number></property>

            <item>
             <layout class="QHBoxLayout">
              <item>
               <widget class="QPushButton" name="btn_nav_start">
                <property name="text"><string>▶ Start Nav2</string></property>
               </widget>
              </item>
              <item>
               <widget class="QPushButton" name="btn_nav_stop">
                <property name="text"><string>■ Stop</string></property>
               </widget>
              </item>
             </layout>
            </item>

            <!-- Nav Status -->
            <item>
             <widget class="QFrame">
              <property name="styleSheet">
               <string notr="true">QFrame { background: #0d1117; border: 1px solid #30363d; border-radius: 4px; }</string>
              </property>
              <layout class="QFormLayout">
               <property name="leftMargin"><number>8</number></property>
     <property name="topMargin"><number>6</number></property>
     <property name="rightMargin"><number>8</number></property>
     <property name="bottomMargin"><number>6</number></property>
               <item row="0" column="0">
                <widget class="QLabel"><property name="text"><string>Status:</string></property></widget>
               </item>
               <item row="0" column="1">
                <widget class="QLabel" name="lbl_nav_status">
                 <property name="text"><string>IDLE</string></property>
                 <property name="styleSheet"><string notr="true">color: #8b949e; font-weight: bold;</string></property>
                </widget>
               </item>
               <item row="1" column="0">
                <widget class="QLabel"><property name="text"><string>Goal:</string></property></widget>
               </item>
               <item row="1" column="1">
                <widget class="QLabel" name="lbl_nav_goal">
                 <property name="text"><string>None</string></property>
                 <property name="styleSheet"><string notr="true">color: #58a6ff;</string></property>
                </widget>
               </item>
               <item row="2" column="0">
                <widget class="QLabel"><property name="text"><string>Distance:</string></property></widget>
               </item>
               <item row="2" column="1">
                <widget class="QLabel" name="lbl_nav_dist">
                 <property name="text"><string>--- m</string></property>
                 <property name="styleSheet"><string notr="true">color: #fbbf24;</string></property>
                </widget>
               </item>
              </layout>
             </widget>
            </item>

            <!-- Goal input -->
            <item>
             <widget class="QLabel">
              <property name="text"><string>Set Goal Position:</string></property>
              <property name="styleSheet"><string notr="true">color: #8b949e;</string></property>
             </widget>
            </item>
            <item>
             <layout class="QFormLayout">
              <item row="0" column="0">
               <widget class="QLabel"><property name="text"><string>X (m):</string></property></widget>
              </item>
              <item row="0" column="1">
               <widget class="QDoubleSpinBox" name="spin_goal_x">
                <property name="minimum"><double>-100.0</double></property>
                <property name="maximum"><double>100.0</double></property>
                <property name="singleStep"><double>0.1</double></property>
                <property name="value"><double>0.0</double></property>
               </widget>
              </item>
              <item row="1" column="0">
               <widget class="QLabel"><property name="text"><string>Y (m):</string></property></widget>
              </item>
              <item row="1" column="1">
               <widget class="QDoubleSpinBox" name="spin_goal_y">
                <property name="minimum"><double>-100.0</double></property>
                <property name="maximum"><double>100.0</double></property>
                <property name="singleStep"><double>0.1</double></property>
                <property name="value"><double>0.0</double></property>
               </widget>
              </item>
              <item row="2" column="0">
               <widget class="QLabel"><property name="text"><string>Yaw (°):</string></property></widget>
              </item>
              <item row="2" column="1">
               <widget class="QDoubleSpinBox" name="spin_goal_yaw">
                <property name="minimum"><double>-180.0</double></property>
                <property name="maximum"><double>180.0</double></property>
                <property name="singleStep"><double>5.0</double></property>
                <property name="value"><double>0.0</double></property>
               </widget>
              </item>
             </layout>
            </item>
            <item>
             <layout class="QHBoxLayout">
              <item>
               <widget class="QPushButton" name="btn_send_goal">
                <property name="text"><string>📍 Send Goal</string></property>
                <property name="styleSheet">
                 <string notr="true">QPushButton { background-color: #1d4ed8; border-color: #3b82f6; color: white; }</string>
                </property>
               </widget>
              </item>
              <item>
               <widget class="QPushButton" name="btn_cancel_goal">
                <property name="text"><string>✕ Cancel</string></property>
               </widget>
              </item>
             </layout>
            </item>

            <!-- Map files -->
            <item>
             <layout class="QHBoxLayout">
              <item>
               <widget class="QLabel"><property name="text"><string>Map:</string></property></widget>
              </item>
              <item>
               <widget class="QLineEdit" name="edit_map_file">
                <property name="placeholderText"><string>map.yaml</string></property>
               </widget>
              </item>
              <item>
               <widget class="QPushButton" name="btn_browse_map">
                <property name="text"><string>...</string></property>
                <property name="maximumWidth"><number>30</number></property>
               </widget>
              </item>
             </layout>
            </item>

           </layout>
          </widget>
         </item>

         <!-- SLAM GROUP -->
         <item>
          <widget class="QGroupBox" name="grp_slam">
           <property name="title"><string> SLAM Toolbox</string></property>
           <layout class="QVBoxLayout">
            <property name="spacing"><number>6</number></property>

            <item>
             <layout class="QHBoxLayout">
              <item>
               <widget class="QPushButton" name="btn_slam_start">
