  <!-- MENU BAR -->
  <widget class="QMenuBar" name="menubar">
   <property name="geometry">
    <rect><x>0</x><y>0</y><width>1400</width><height>28</height></rect>
   </property>
   <property name="styleSheet">
    <string notr="true">
QMenuBar { background-color: #161b22; border-bottom: 1px solid #30363d; color: #e6edf3; }
QMenuBar::item:selected { background-color: #21262d; }
QMenu { background-color: #161b22; border: 1px solid #30363d; color: #e6edf3; }
QMenu::item:selected { background-color: #1f6feb; }
    </string>
   </property>
   <widget class="QMenu" name="menu_file">
    <property name="title"><string>&amp;File</string></property>
    <addaction name="action_open_config"/>
    <addaction name="action_save_config"/>
    <addaction name="separator"/>
    <addaction name="action_exit"/>
   </widget>
   <widget class="QMenu" name="menu_robot">
    <property name="title"><string>&amp;Robot</string></property>
    <addaction name="action_launch_bringup"/>
    <addaction name="action_kill_all_nodes"/>
    <addaction name="separator"/>
    <addaction name="action_calibrate_odom"/>
   </widget>
   <widget class="QMenu" name="menu_view">
    <property name="title"><string>&amp;View</string></property>
    <addaction name="action_show_rviz"/>
    <addaction name="action_show_rqt"/>
   </widget>
   <widget class="QMenu" name="menu_help">
    <property name="title"><string>&amp;Help</string></property>
    <addaction name="action_about"/>
   </widget>
   <addaction name="menu_file"/>
   <addaction name="menu_robot"/>
   <addaction name="menu_view"/>
   <addaction name="menu_help"/>
  </widget>

  <!-- STATUS BAR -->
